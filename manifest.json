{
  "manifest_version": 3,
  "name": "飞摘：飞书到 Obsidian",
  "short_name": "飞摘",
  "version": "0.1.0",
  "description": "把当前飞书 Wiki 或文档正文和图片摘入 Obsidian Vault。",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://*.feishu.cn/*"],
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_title": "飞摘",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.feishu.cn/wiki/*", "https://*.feishu.cn/docx/*", "https://*.feishu.cn/docs/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/content-core.js"],
      "matches": ["https://*.feishu.cn/*"]
    }
  ]
}
